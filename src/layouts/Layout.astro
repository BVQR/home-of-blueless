---
// 基础布局组件 - 所有页面共用的 HTML 壳
interface Props {
  title?: string;
}
const { title = 'BL Blog' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- 各页面可通过 slot="head" 注入字体链接等额外头部资源 -->
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* 全局样式重置 */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    width: 100%;
    min-height: 100%;
    overflow-x: hidden;
  }

  body {
    /* 优先使用系统中文字体 */
    font-family:
      -apple-system, BlinkMacSystemFont,
      'Segoe UI', 'PingFang SC',
      'Hiragino Sans GB', 'Microsoft YaHei',
      sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a {
    text-decoration: none;
    color: inherit;
  }
</style>
