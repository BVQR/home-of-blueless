---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import BlogSidebar from '../../../components/BlogSidebar.astro';

export async function getStaticPaths() {
  const posts = await getCollection('exploreing');
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

type Props = { post: CollectionEntry<'exploreing'> };
const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection('exploreing');
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={`${post.data.title} · BL Blog`}>
  <canvas id="ripple-canvas" aria-hidden="true"></canvas>
  <div class="entry-overlay" aria-hidden="true"></div>
  <div class="page-bg" aria-hidden="true">
    <div class="bg-orb bg-orb-1"></div>
    <div class="bg-orb bg-orb-2"></div>
  </div>

  <header class="top-bar reveal-fade" id="header">
    <div class="left-bar">
      <div class="page-icon" aria-label="探索">
        <svg viewBox="0 0 28 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="7" width="24" height="15" rx="2.5"/>
          <circle cx="14" cy="14.5" r="4"/>
          <path d="M10 7L12 3h4l2 4"/>
          <circle cx="22" cy="11" r="1.3" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <a href="/" class="home-btn" aria-label="返回主页">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 10L10 3l7 7M5 8.5V17h4v-4h2v4h4V8.5"/>
        </svg>
        <span>主页</span>
      </a>
    </div>
    <button class="sb-toggle-btn" id="sb-toggle" aria-label="打开目录">
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="17" y2="6"/>
        <line x1="3" y1="10" x2="17" y2="10"/>
        <line x1="3" y1="14" x2="17" y2="14"/>
      </svg>
      <span>目录</span>
    </button>
  </header>

  <BlogSidebar posts={allPosts} currentSlug={post.id} basePath="/blog/exploreing" categoryName="探索" />

  <main class="content-main reveal-fade" id="content">
    <article class="prose">
      <h1 class="article-title">{post.data.title}</h1>
      <div class="article-meta">
        <time>{formatDate(post.data.date)}</time>
        {post.data.tags.map(tag => <span class="meta-tag">{tag}</span>)}
      </div>
      <div class="article-divider" aria-hidden="true"></div>
      <div class="prose-body">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  :root {
    --e1: #22577a; --e2: #38a3a5; --e3: #57cc99; --e4: #80ed99; --e5: #c7f9cc;
    --bg-deep: #0d2b38;
    --text-light: rgba(230, 252, 245, 0.92);
    --text-dim:   rgba(135, 215, 185, 0.62);
    --sb-bg:            rgba(10, 34, 44, 0.55);
    --sb-border:        rgba(87, 204, 153, 0.18);
    --sb-header-color:  rgba(87, 204, 153, 0.9);
    --sb-text:          rgba(230, 252, 245, 0.88);
    --sb-text-dim:      rgba(135, 215, 185, 0.55);
    --sb-tag-bg:        rgba(56, 163, 165, 0.12);
    --sb-tag-border:    rgba(87, 204, 153, 0.22);
    --sb-tag-text:      rgba(128, 237, 153, 0.8);
    --sb-active-bg:     rgba(87, 204, 153, 0.18);
    --sb-active-border: #57cc99;
    --sb-hover-bg:      rgba(87, 204, 153, 0.09);
    --sb-scrollbar:     rgba(87, 204, 153, 0.25);
  }

  #ripple-canvas {
    position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.5;
  }

  .entry-overlay {
    position: fixed; inset: 0; z-index: 100;
    background: linear-gradient(145deg, var(--bg-deep) 0%, var(--e1) 55%, var(--e2) 100%);
    pointer-events: none;
    transform-origin: bottom center;
    animation: overlayUp 0.9s cubic-bezier(0.76,0,0.24,1) 0.25s forwards;
  }
  @keyframes overlayUp {
    0%   { transform: scaleY(1); opacity: 1; }
    100% { transform: scaleY(0); opacity: 1; }
  }

  .page-bg {
    position: fixed; inset: 0; z-index: -1;
    background: var(--bg-deep); overflow: hidden;
  }
  .bg-orb { position: absolute; border-radius: 50%; filter: blur(110px); }
  .bg-orb-1 {
    width: 55vw; height: 55vw;
    background: radial-gradient(circle, var(--e2), var(--e1), transparent);
    top: -18%; right: -12%; opacity: 0.45;
    animation: bob1 15s ease-in-out infinite;
  }
  .bg-orb-2 {
    width: 50vw; height: 50vw;
    background: radial-gradient(circle, var(--e3), var(--e1), transparent);
    bottom: -12%; left: -8%; opacity: 0.38;
    animation: bob2 19s ease-in-out infinite;
  }
  @keyframes bob1 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(-5vw,6vh); } }
  @keyframes bob2 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(5vw,-5vh); } }

  .reveal-fade {
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }
  .reveal-fade.visible { opacity: 1; transform: none; }

  .top-bar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.2rem 1.8rem;
    background: rgba(13, 43, 56, 0.48);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(87, 204, 153, 0.18);
  }

  .left-bar { display: flex; align-items: center; gap: 1rem; }

  .page-icon { color: var(--e3); opacity: 0.75; }
  .page-icon svg { width: 1.7rem; height: 1.5rem; }

  .home-btn {
    display: flex; align-items: center; gap: .45rem;
    font-size: .85rem; font-weight: 500; letter-spacing: .04em;
    color: var(--text-dim);
    transition: color .25s ease, transform .25s ease;
  }
  .home-btn svg { width: 1.1rem; height: 1.1rem; }
  .home-btn:hover { color: var(--text-light); transform: translateX(-3px); }

  .sb-toggle-btn {
    display: none; align-items: center; gap: 0.4rem;
    padding: 0.4rem 0.9rem; font-size: 0.8rem; font-weight: 500; letter-spacing: 0.06em;
    color: var(--text-dim); background: rgba(87,204,153,0.1);
    border: 1px solid rgba(87,204,153,0.2); border-radius: 100px;
    cursor: pointer; transition: color 0.2s, background 0.2s;
  }
  .sb-toggle-btn svg { width: 1rem; height: 1rem; }
  .sb-toggle-btn:hover { color: var(--text-light); background: rgba(87,204,153,0.18); }

  .content-main {
    margin-left: 260px; min-height: 100svh;
    padding: 7rem 4rem 4rem 3.5rem;
    position: relative; z-index: 1;
    display: flex; justify-content: center;
  }

  .prose { width: 100%; max-width: 720px; }

  .article-title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 700;
    color: var(--text-light); letter-spacing: -0.02em; line-height: 1.25;
    margin-bottom: 0.8rem;
  }

  .article-meta {
    display: flex; align-items: center; gap: 0.5rem;
    flex-wrap: wrap; margin-bottom: 1.5rem;
  }
  .article-meta time { font-size: 0.8rem; color: var(--text-dim); letter-spacing: 0.04em; }
  .meta-tag {
    font-size: 0.68rem; padding: 0.15rem 0.55rem;
    background: var(--sb-tag-bg); border: 1px solid var(--sb-tag-border);
    border-radius: 999px; color: var(--sb-tag-text);
  }

  .article-divider {
    height: 1px;
    background: linear-gradient(90deg, var(--sb-active-border), transparent);
    margin-bottom: 2rem; opacity: 0.45;
  }

  .prose-body { font-size: 1.05rem; line-height: 1.9; color: var(--text-dim); letter-spacing: 0.01em; }
  .prose-body :global(h2) { font-size: 1.45rem; font-weight: 600; color: var(--text-light); margin-top: 2.5rem; margin-bottom: 0.8rem; }
  .prose-body :global(h3) { font-size: 1.2rem; font-weight: 600; color: var(--text-light); margin-top: 2rem; margin-bottom: 0.6rem; }
  .prose-body :global(p) { margin-bottom: 1.4rem; }
  .prose-body :global(ul), .prose-body :global(ol) { padding-left: 1.5rem; margin-bottom: 1.4rem; }
  .prose-body :global(li) { margin-bottom: 0.4rem; }
  .prose-body :global(blockquote) {
    border-left: 3px solid var(--sb-active-border); padding: 0.5rem 1rem;
    margin: 1.5rem 0; opacity: 0.8; font-style: italic;
  }
  .prose-body :global(code) {
    background: rgba(255,255,255,0.08); padding: 0.15rem 0.4rem;
    border-radius: 4px; font-size: 0.88em;
  }
  .prose-body :global(pre) {
    background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px; padding: 1.2rem 1.5rem; overflow-x: auto; margin-bottom: 1.5rem;
  }
  .prose-body :global(pre code) { background: none; padding: 0; }
  .prose-body :global(a) { color: var(--sb-active-border); text-decoration: underline; text-underline-offset: 3px; }
  .prose-body :global(hr) { border: none; border-top: 1px solid rgba(255,255,255,0.12); margin: 2.5rem 0; }
  .prose-body :global(strong) { color: var(--text-light); font-weight: 600; }
  .prose-body :global(img) { max-width: 100%; border-radius: 8px; margin: 1rem 0; }

  @media (max-width: 860px) {
    .content-main { margin-left: 0; padding: 6rem 1.5rem 3rem; }
    .sb-toggle-btn { display: flex; }
  }
  @media (max-width: 560px) { .article-title { font-size: 1.5rem; } }
</style>

<script>
  const canvas = document.getElementById('ripple-canvas') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;
  function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
  resize(); window.addEventListener('resize', resize);

  interface Ripple { x:number;y:number;r:number;maxR:number;opacity:number;speed:number; }
  const ripples: Ripple[] = [];

  function addRipple() {
    ripples.push({
      x: Math.random()*canvas.width, y: Math.random()*canvas.height,
      r: 0, maxR: Math.random()*180+80,
      opacity: 0.18, speed: Math.random()*0.6+0.3,
    });
  }

  setInterval(addRipple, 1200);
  for (let i=0;i<4;i++) setTimeout(addRipple, i*300);

  (function loop(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    for(let i=ripples.length-1;i>=0;i--){
      const rp=ripples[i];
      rp.r+=rp.speed; rp.opacity-=0.0008;
      if(rp.opacity<=0||rp.r>rp.maxR){ripples.splice(i,1);continue;}
      ctx.beginPath(); ctx.arc(rp.x,rp.y,rp.r,0,Math.PI*2);
      ctx.strokeStyle=`rgba(87,204,153,${rp.opacity})`; ctx.lineWidth=1.5; ctx.stroke();
    }
    requestAnimationFrame(loop);
  })();

  const ov=document.querySelector('.entry-overlay') as HTMLElement;
  ov?.addEventListener('animationend',()=>ov.remove(),{once:true});

  const DELAY=1150;
  setTimeout(()=>document.getElementById('header')?.classList.add('visible'),DELAY);
  setTimeout(()=>document.getElementById('content')?.classList.add('visible'),DELAY+200);
</script>
