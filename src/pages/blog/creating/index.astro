---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import BlogSidebar from '../../../components/BlogSidebar.astro';

const allPosts = await getCollection('creating');
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const post = allPosts[0];

let Content: any = null;
if (post) {
  const rendered = await render(post);
  Content = rendered.Content;
}

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

{!post && (
  <html lang="zh-CN">
  <head><meta charset="UTF-8"><title>创造 · BL Blog</title></head>
  <body style="background:#1a0d3d;color:rgba(220,180,120,0.6);display:flex;align-items:center;justify-content:center;height:100vh;font-family:sans-serif;letter-spacing:0.1em;">
    暂无文章 · <a href="/blog" style="color:#f7b801;margin-left:0.5rem">返回博客</a>
  </body>
  </html>
)}
{post && (
  <Layout title={`${post.data.title} · BL Blog`}>
    <canvas id="spark-canvas" aria-hidden="true"></canvas>
    <div class="entry-overlay" aria-hidden="true"></div>
    <div class="page-bg" aria-hidden="true">
      <div class="bg-orb bg-orb-1"></div>
      <div class="bg-orb bg-orb-2"></div>
      <div class="bg-orb bg-orb-3"></div>
    </div>

    <header class="top-bar reveal-fade" id="header">
      <div class="left-bar">
        <div class="page-icon" aria-label="创造">
          <svg viewBox="0 0 24 28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8.5 22c0-2-1.5-3.5-2.5-5.5A7 7 0 1 1 18 16.5c-1 2-2.5 3.5-2.5 5.5h-7z"/>
            <line x1="8.5" y1="24.5" x2="15.5" y2="24.5"/>
            <line x1="9.5" y1="27" x2="14.5" y2="27"/>
          </svg>
        </div>
        <a href="/" class="home-btn" aria-label="返回主页">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 10L10 3l7 7M5 8.5V17h4v-4h2v4h4V8.5"/>
          </svg>
          <span>主页</span>
        </a>
      </div>
      <button class="sb-toggle-btn" id="sb-toggle" aria-label="打开目录">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="17" y2="6"/>
          <line x1="3" y1="10" x2="17" y2="10"/>
          <line x1="3" y1="14" x2="17" y2="14"/>
        </svg>
        <span>目录</span>
      </button>
    </header>

    <BlogSidebar posts={allPosts} currentSlug={post.id} basePath="/blog/creating" categoryName="创造" />

    <main class="content-main reveal-fade" id="content">
      <article class="prose">
        <h1 class="article-title">{post.data.title}</h1>
        <div class="article-meta">
          <time>{formatDate(post.data.date)}</time>
          {post.data.tags.map(tag => <span class="meta-tag">{tag}</span>)}
        </div>
        <div class="article-divider" aria-hidden="true"></div>
        <div class="prose-body">
          <Content />
        </div>
      </article>
    </main>
  </Layout>
)}

<style>
  :root {
    --cr1: #3d348b; --cr2: #7678ed; --cr3: #f7b801; --cr4: #f18701; --cr5: #f35b04;
    --bg-deep: #1a0d3d;
    --text-light: rgba(255, 240, 210, 0.92);
    --text-dim:   rgba(220, 180, 120, 0.62);
    --sb-bg:            rgba(20, 8, 52, 0.58);
    --sb-border:        rgba(118, 120, 237, 0.22);
    --sb-header-color:  rgba(247, 184, 1, 0.9);
    --sb-text:          rgba(255, 240, 210, 0.88);
    --sb-text-dim:      rgba(220, 180, 120, 0.55);
    --sb-tag-bg:        rgba(118, 120, 237, 0.12);
    --sb-tag-border:    rgba(247, 184, 1, 0.22);
    --sb-tag-text:      rgba(247, 184, 1, 0.8);
    --sb-active-bg:     rgba(247, 184, 1, 0.12);
    --sb-active-border: #f7b801;
    --sb-hover-bg:      rgba(118, 120, 237, 0.1);
    --sb-scrollbar:     rgba(247, 184, 1, 0.2);
  }

  #spark-canvas {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
  }

  .entry-overlay {
    position: fixed; inset: 0; z-index: 100;
    background: linear-gradient(130deg, var(--bg-deep) 0%, var(--cr1) 45%, var(--cr2) 100%);
    pointer-events: none;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
    animation: overlayWipe 0.9s cubic-bezier(0.87,0,0.13,1) 0.2s forwards;
  }
  @keyframes overlayWipe {
    0%   { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
    100% { clip-path: polygon(110% 0, 110% 0, 110% 100%, 110% 100%); }
  }

  .page-bg {
    position: fixed; inset: 0; z-index: -1;
    background: var(--bg-deep); overflow: hidden;
  }
  .bg-orb { position: absolute; border-radius: 50%; filter: blur(100px); }
  .bg-orb-1 {
    width: 55vw; height: 55vw;
    background: radial-gradient(circle, var(--cr2), var(--cr1), transparent);
    top: -15%; left: -10%; opacity: 0.45;
    animation: cBob1 14s ease-in-out infinite;
  }
  .bg-orb-2 {
    width: 50vw; height: 50vw;
    background: radial-gradient(circle, var(--cr5), var(--cr4), transparent);
    bottom: -15%; right: -10%; opacity: 0.4;
    animation: cBob2 18s ease-in-out infinite;
  }
  .bg-orb-3 {
    width: 30vw; height: 30vw;
    background: radial-gradient(circle, var(--cr3), transparent);
    top: 40%; right: 25%; opacity: 0.2;
    animation: cBob3 11s ease-in-out infinite;
  }
  @keyframes cBob1 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(4vw,5vh); } }
  @keyframes cBob2 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(-5vw,-5vh); } }
  @keyframes cBob3 { 0%,100% { transform: translate(0,0); opacity:.2; } 50% { transform: translate(-3vw,4vh); opacity:.35; } }

  .reveal-fade {
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }
  .reveal-fade.visible { opacity: 1; transform: none; }

  .top-bar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.2rem 1.8rem;
    background: rgba(26, 13, 61, 0.48);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(118, 120, 237, 0.18);
  }

  .left-bar { display: flex; align-items: center; gap: 1rem; }

  .page-icon { color: var(--cr3); opacity: 0.8; }
  .page-icon svg { width: 1.4rem; height: 1.65rem; }

  .home-btn {
    display: flex; align-items: center; gap: .45rem;
    font-size: .85rem; font-weight: 500; letter-spacing: .04em;
    color: var(--text-dim);
    transition: color .25s ease, transform .25s ease;
  }
  .home-btn svg { width: 1.1rem; height: 1.1rem; }
  .home-btn:hover { color: var(--text-light); transform: translateX(-3px); }

  .sb-toggle-btn {
    display: none; align-items: center; gap: 0.4rem;
    padding: 0.4rem 0.9rem; font-size: 0.8rem; font-weight: 500; letter-spacing: 0.06em;
    color: var(--text-dim); background: rgba(247,184,1,0.1);
    border: 1px solid rgba(247,184,1,0.2); border-radius: 100px;
    cursor: pointer; transition: color 0.2s, background 0.2s;
  }
  .sb-toggle-btn svg { width: 1rem; height: 1rem; }
  .sb-toggle-btn:hover { color: var(--text-light); background: rgba(247,184,1,0.18); }

  .content-main {
    margin-left: 260px; min-height: 100svh;
    padding: 7rem 4rem 4rem 3.5rem;
    position: relative; z-index: 1;
    display: flex; justify-content: center;
  }

  .prose { width: 100%; max-width: 720px; }

  .article-title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 700;
    color: var(--text-light); letter-spacing: -0.02em; line-height: 1.25;
    margin-bottom: 0.8rem;
  }

  .article-meta {
    display: flex; align-items: center; gap: 0.5rem;
    flex-wrap: wrap; margin-bottom: 1.5rem;
  }
  .article-meta time { font-size: 0.8rem; color: var(--text-dim); letter-spacing: 0.04em; }
  .meta-tag {
    font-size: 0.68rem; padding: 0.15rem 0.55rem;
    background: var(--sb-tag-bg); border: 1px solid var(--sb-tag-border);
    border-radius: 999px; color: var(--sb-tag-text);
  }

  .article-divider {
    height: 1px;
    background: linear-gradient(90deg, var(--sb-active-border), transparent);
    margin-bottom: 2rem; opacity: 0.45;
  }

  .prose-body { font-size: 1.05rem; line-height: 1.9; color: var(--text-dim); letter-spacing: 0.01em; }
  .prose-body :global(h2) { font-size: 1.45rem; font-weight: 600; color: var(--text-light); margin-top: 2.5rem; margin-bottom: 0.8rem; }
  .prose-body :global(h3) { font-size: 1.2rem; font-weight: 600; color: var(--text-light); margin-top: 2rem; margin-bottom: 0.6rem; }
  .prose-body :global(p) { margin-bottom: 1.4rem; }
  .prose-body :global(ul), .prose-body :global(ol) { padding-left: 1.5rem; margin-bottom: 1.4rem; }
  .prose-body :global(li) { margin-bottom: 0.4rem; }
  .prose-body :global(blockquote) {
    border-left: 3px solid var(--sb-active-border); padding: 0.5rem 1rem;
    margin: 1.5rem 0; opacity: 0.8; font-style: italic;
  }
  .prose-body :global(code) {
    background: rgba(255,255,255,0.08); padding: 0.15rem 0.4rem;
    border-radius: 4px; font-size: 0.88em;
  }
  .prose-body :global(pre) {
    background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px; padding: 1.2rem 1.5rem; overflow-x: auto; margin-bottom: 1.5rem;
  }
  .prose-body :global(pre code) { background: none; padding: 0; }
  .prose-body :global(a) { color: var(--sb-active-border); text-decoration: underline; text-underline-offset: 3px; }
  .prose-body :global(hr) { border: none; border-top: 1px solid rgba(255,255,255,0.12); margin: 2.5rem 0; }
  .prose-body :global(strong) { color: var(--text-light); font-weight: 600; }
  .prose-body :global(img) { max-width: 100%; border-radius: 8px; margin: 1rem 0; }

  @media (max-width: 860px) {
    .content-main { margin-left: 0; padding: 6rem 1.5rem 3rem; }
    .sb-toggle-btn { display: flex; }
  }
  @media (max-width: 560px) { .article-title { font-size: 1.5rem; } }
</style>

<script>
  const canvas = document.getElementById('spark-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
    resize(); window.addEventListener('resize', resize);

    interface Spark {
      x:number;y:number;vx:number;vy:number;r:number;
      opacity:number;hue:number;life:number;maxLife:number;
    }
    const sparks: Spark[] = [];

    function spawnSpark(): Spark {
      const maxLife = Math.random()*120+60;
      return {
        x: Math.random()*canvas.width, y: canvas.height+10,
        vx: (Math.random()-0.5)*1.2, vy: -(Math.random()*1.8+0.8),
        r: Math.random()*2.5+0.8,
        opacity: Math.random()*0.6+0.3,
        hue: Math.random()*30+10,
        life: 0, maxLife,
      };
    }

    for(let i=0;i<45;i++){
      const s=spawnSpark();
      s.y=Math.random()*canvas.height;
      s.life=Math.floor(Math.random()*s.maxLife*0.5);
      sparks.push(s);
    }

    function refill(){ while(sparks.length<55) sparks.push(spawnSpark()); }

    (function loop(){
      ctx.clearRect(0,0,canvas.width,canvas.height);
      for(let i=sparks.length-1;i>=0;i--){
        const s=sparks[i];
        s.x+=s.vx; s.y+=s.vy; s.vy-=0.015;
        s.vx+=(Math.random()-0.5)*0.05; s.life++;
        const decay=1-s.life/s.maxLife;
        s.opacity=Math.max(0,s.opacity*0.998)*decay;
        if(s.life>=s.maxLife||s.y<-20){sparks.splice(i,1);continue;}
        const g=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,s.r*2.5);
        g.addColorStop(0,`hsla(${s.hue+30},100%,75%,${s.opacity})`);
        g.addColorStop(0.4,`hsla(${s.hue},100%,55%,${s.opacity*0.7})`);
        g.addColorStop(1,`hsla(${s.hue-10},90%,40%,0)`);
        ctx.fillStyle=g; ctx.beginPath(); ctx.arc(s.x,s.y,s.r*2.5,0,Math.PI*2); ctx.fill();
      }
      refill(); requestAnimationFrame(loop);
    })();

    const VISITED_KEY = 'bl-visited-creating';
    const ov = document.querySelector('.entry-overlay') as HTMLElement;
    if (sessionStorage.getItem(VISITED_KEY)) {
      ov?.remove();
      document.getElementById('header')?.classList.add('visible');
      document.getElementById('content')?.classList.add('visible');
    } else {
      sessionStorage.setItem(VISITED_KEY, '1');
      ov?.addEventListener('animationend', () => ov.remove(), { once: true });
      const DELAY = 1100;
      setTimeout(() => document.getElementById('header')?.classList.add('visible'), DELAY);
      setTimeout(() => document.getElementById('content')?.classList.add('visible'), DELAY + 200);
    }
  }
</script>