---
import { getCollection } from 'astro:content';
const posts = await getCollection('fogging');
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
if (posts.length > 0) {
  return Astro.redirect(`/blog/fogging/${posts[0].id}`);
}
