---
import { getCollection } from 'astro:content';
const posts = await getCollection('thinking');
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
if (posts.length > 0) {
  return Astro.redirect(`/blog/thinking/${posts[0].id}`);
}
---
<!doctype html>
<html lang="zh-CN">
<head><meta charset="UTF-8"><title>思考 · BL Blog</title></head>
<body style="background:rgba(205,220,248,0.95);color:rgba(30,50,100,0.8);display:flex;align-items:center;justify-content:center;height:100vh;font-family:sans-serif;letter-spacing:0.1em;">
  暂无文章 · <a href="/blog" style="color:#6c9ee8;margin-left:0.5rem">返回博客</a>
</body>
</html>
