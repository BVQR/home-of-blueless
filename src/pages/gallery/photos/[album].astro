---
import Layout from '../../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

/* ── introduce.md 解析器 ───────────────────────────────────────────── */
interface IntroData {
  info: Record<string, string>;
  story: string;
  tagline: string;
}

function parseIntroduce(raw: string): IntroData {
  const normalized = raw.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
  const [infoSec = '', storySec = '', tagSec = ''] = normalized.split(/\n---\n/);
  const info: Record<string, string> = {};
  for (const line of infoSec.split('\n')) {
    const m = line.match(/^-\s*([^:\n]+):\s*(.+)$/);
    if (m) info[m[1].trim().toLowerCase()] = m[2].trim();
  }
  const storyMatch = storySec.match(/story:\s*([\s\S]*)/);
  const story = storyMatch ? storyMatch[1].trim() : '';
  const tagline = tagSec.trim().replace(/^\*+|\*+$/g, '').trim();
  return { info, story, tagline };
}


/* ── 静态路径生成（只列目录名，数据在 frontmatter 中读取） ─────────── */
export async function getStaticPaths() {
  const photosBase = path.join(process.cwd(), 'public', 'images', 'photos');
  if (!fs.existsSync(photosBase)) return [];
  return fs.readdirSync(photosBase)
    .filter(n => fs.statSync(path.join(photosBase, n)).isDirectory())
    .map(slug => ({ params: { album: slug } }));
}

/* ── 每次渲染时读取数据 ────────────────────────────────────────────── */
const slug = Astro.params.album;
const photosBase = path.join(process.cwd(), 'public', 'images', 'photos');
const dir    = path.join(photosBase, slug);
const mdPath = path.join(dir, 'introduce.md');
const raw    = fs.existsSync(mdPath) ? fs.readFileSync(mdPath, 'utf-8') : '';
const introduce = parseIntroduce(raw);

const IMG = /\.(jpe?g|png|webp|gif|avif)$/i;
const images = fs.readdirSync(dir).filter(f => IMG.test(f)).sort().map(f => `/images/photos/${slug}/${f}`);
const title = slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
const { info, story, tagline } = introduce;
const cover = images[0] ?? null;

const INFO_FIELDS = [
  { key: 'date',       label: '时间', icon: '🗓' },
  { key: 'address',    label: '地点', icon: '📍' },
  { key: 'device',     label: '设备', icon: '📷' },
  { key: 'parameters', label: '参数', icon: '⚙' },
] as const;
---

<Layout title={`${title} | 快门瞬息`}>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&family=Playfair+Display:ital@0;1&display=swap" />

  <div class="page-bg" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
  </div>

  <!-- Hero 封面区 -->
  <section class="hero">
    {cover && <img class="hero-img" src={cover} alt={title} />}
    <div class="hero-gradient"></div>

    <nav class="hero-nav layer-item" id="topnav">
      <a href="/gallery/photos" class="nav-link nav-back">← 相册</a>
      <a href="/" class="nav-link">主页</a>
      <a href="/gallery" class="nav-link">照片墙</a>
    </nav>

    <div class="hero-caption layer-item" id="caption">
      <h1 class="hero-title">{title}</h1>
    </div>
  </section>

  <!-- 拍摄信息（照片上方） -->
  <div class="info-wrap layer-item" id="meta">
    <div class="info-card glass-card">
      <h3 class="card-heading">拍摄信息</h3>
      <ul class="info-list">
        {INFO_FIELDS.map(({ key, label, icon }) =>
          info[key] ? (
            <li class="info-item">
              <span class="info-icon">{icon}</span>
              <div>
                <span class="info-label">{label}</span>
                <span class="info-val">{info[key]}</span>
              </div>
            </li>
          ) : null
        )}
      </ul>
    </div>
  </div>

  <!-- 照片瀑布流 -->
  <section class="photo-section layer-item" id="photos">
    <h2 class="section-label">所有照片 · {images.length} 张</h2>
    <div class="photo-grid">
      {images.map(src => (
        <figure class="photo-item" data-src={src}>
          <img src={src} alt="" loading="lazy" />
        </figure>
      ))}
    </div>
  </section>

  <!-- 故事 + 标语（照片下方） -->
  {(story || tagline) && (
    <div class="story-wrap layer-item" id="story">
      {story && (
        <div class="story-card glass-card">
          <h3 class="card-heading">记录</h3>
          <p class="story-text">{story}</p>
        </div>
      )}
      {tagline && (
        <p class="story-tagline">{tagline}</p>
      )}
    </div>
  )}

  <!-- 图片灯箱 -->
  <div class="lightbox" id="lightbox" aria-modal="true" role="dialog" aria-hidden="true">
    <div class="lb-backdrop"></div>
    <div class="lb-card">
      <div class="lb-toolbar">
        <a class="lb-btn lb-download" id="lb-download" download aria-label="下载">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </a>
        <button class="lb-btn lb-close" id="lb-close" aria-label="关闭">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="lb-img-wrap" id="lb-img-wrap">
        <img class="lb-img" id="lb-img" src="" alt="" draggable="false" />
      </div>
      <p class="lb-hint">滚轮缩放 · 拖拽移动</p>
    </div>
  </div>
</Layout>

<style>
  :root {
    --c1: #31572c;
    --c2: #4f772d;
    --c3: #90a955;
    --c4: #ecf39e;
    --bg-dark: #0d1a09;
  }

  .page-bg {
    position: fixed; inset: 0; z-index: -1;
    background: var(--bg-dark); overflow: hidden;
  }
  .orb { position: absolute; border-radius: 50%; filter: blur(90px); }
  .orb-1 {
    width: 60vw; height: 60vw;
    background: radial-gradient(circle, var(--c2) 0%, var(--c1) 60%, transparent 100%);
    top: -15%; right: -10%; opacity: 0.45;
    animation: float1 14s ease-in-out infinite;
  }
  .orb-2 {
    width: 45vw; height: 45vw;
    background: radial-gradient(circle, var(--c1) 0%, transparent 100%);
    bottom: -10%; left: -8%; opacity: 0.4;
    animation: float2 18s ease-in-out infinite;
  }
  @keyframes float1 {
    0%,100% { transform: translate(0,0) scale(1); }
    50%     { transform: translate(-3vw, 5vh) scale(1.07); }
  }
  @keyframes float2 {
    0%,100% { transform: translate(0,0) scale(1); }
    50%     { transform: translate(5vw, -5vh) scale(1.1); }
  }

  .layer-item {
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1),
                transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .layer-item.visible { opacity: 1; transform: none; }

  /* ── Hero ─────────────────────────────────── */
  .hero {
    position: relative;
    height: 62vh; min-height: 400px;
    overflow: hidden;
  }
  .hero-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; filter: brightness(0.82);
    transition: transform 8s ease;
  }
  .hero:hover .hero-img { transform: scale(1.04); }

  .hero-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.28) 0%,
      transparent 35%,
      rgba(13,26,9,0.55) 70%,
      rgba(13,26,9,0.94) 100%
    );
  }

  .hero-nav {
    position: absolute; top: 1.4rem; right: 1.6rem;
    z-index: 10; display: flex; gap: 0.6rem;
  }
  .nav-link {
    padding: 0.45rem 1.1rem;
    font-size: 0.82rem; font-weight: 600; letter-spacing: 0.1em;
    color: rgba(255,255,255,0.82);
    background: rgba(0,0,0,0.32);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 100px; text-decoration: none;
    transition: color 0.3s, background 0.3s;
    font-family: 'Noto Sans SC', sans-serif;
  }
  .nav-link:hover { color: #fff; background: rgba(255,255,255,0.15); }
  .nav-back { color: rgba(236,243,158,0.9); }

  .hero-caption {
    position: absolute; bottom: 2.8rem;
    left: clamp(1.5rem, 5vw, 4rem); right: clamp(1.5rem, 5vw, 4rem);
  }
  .hero-title {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: clamp(2rem, 6vw, 4.2rem);
    font-weight: 700; color: #fff; letter-spacing: 0.04em;
    text-shadow: 0 2px 24px rgba(0,0,0,0.55);
  }

  /* ── 拍摄信息区（照片上方）─────────────────── */
  .info-wrap {
    max-width: 1200px; margin: 0 auto;
    padding: 2.5rem clamp(1.5rem, 5vw, 4rem) 1.5rem;
    color: #fff;
  }

  .info-card {
    display: inline-flex; flex-wrap: wrap;
    gap: 0.5rem 2.5rem;
    align-items: flex-start;
  }

  .glass-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 18px; padding: 1.4rem 1.8rem;
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  }

  .card-heading {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.7rem; font-weight: 500;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(144,169,85,0.85);
    margin-bottom: 1.1rem; width: 100%;
  }

  .info-list {
    list-style: none;
    display: flex; flex-wrap: wrap;
    gap: 0.9rem 2.2rem;
  }

  .info-item { display: flex; align-items: flex-start; gap: 0.6rem; }

  .info-icon { font-size: 1rem; line-height: 1.5; flex-shrink: 0; opacity: 0.85; }

  .info-label {
    display: block;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.66rem; color: rgba(255,255,255,0.38);
    letter-spacing: 0.1em; margin-bottom: 0.1rem;
  }
  .info-val {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.88rem; color: rgba(255,255,255,0.88);
    letter-spacing: 0.04em; line-height: 1.55;
  }

  /* ── 照片区 ───────────────────────────────── */
  .photo-section {
    max-width: 1200px; margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem) 3rem;
    color: #fff;
  }

  .section-label {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.75rem; font-weight: 500;
    letter-spacing: 0.16em; color: rgba(144,169,85,0.65);
    margin-bottom: 1.5rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .photo-grid { columns: 3 260px; column-gap: 1rem; }

  .photo-item {
    break-inside: avoid; margin-bottom: 1rem;
    border-radius: 10px; overflow: hidden;
    cursor: zoom-in;
    transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.35s;
  }
  .photo-item:hover {
    transform: scale(1.02);
    box-shadow: 0 14px 40px rgba(79,119,45,0.4);
  }
  .photo-item img { width: 100%; height: auto; display: block; }

  /* ── 故事区（照片下方）──────────────────────── */
  .story-wrap {
    max-width: 760px; margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem) 6rem;
    color: #fff;
    display: flex; flex-direction: column; align-items: center; gap: 1.6rem;
  }

  .story-card {
    width: 100%;
    border-top: 1px solid rgba(144,169,85,0.25);
  }

  .story-text {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 1rem; font-weight: 300;
    line-height: 2; color: rgba(255,255,255,0.8);
    letter-spacing: 0.07em;
  }

  .story-tagline {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: clamp(1rem, 2.2vw, 1.25rem);
    color: rgba(236,243,158,0.75);
    letter-spacing: 0.06em;
    text-align: center;
    line-height: 1.7;
  }

  /* ── 灯箱 ─────────────────────────────────── */
  .lightbox {
    position: fixed; inset: 0; z-index: 1000;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .lightbox.open {
    opacity: 1; pointer-events: all;
  }

  .lb-backdrop {
    position: absolute; inset: 0;
    background: rgba(8,16,6,0.88);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  }

  .lb-card {
    position: relative; z-index: 1;
    display: flex; flex-direction: column;
    width: min(92vw, 1100px);
    max-height: 92vh;
    background: rgba(20,32,16,0.7);
    border: 1px solid rgba(144,169,85,0.22);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,0.7);
    transform: scale(0.94);
    transition: transform 0.28s cubic-bezier(0.16,1,0.3,1);
  }
  .lightbox.open .lb-card { transform: scale(1); }

  .lb-toolbar {
    position: absolute; top: 0.9rem; right: 1rem;
    z-index: 10; display: flex; gap: 0.6rem; align-items: center;
  }

  .lb-btn {
    display: flex; align-items: center; justify-content: center;
    width: 2.4rem; height: 2.4rem;
    background: rgba(0,0,0,0.45);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 50%; cursor: pointer; color: #fff;
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    transition: background 0.2s, transform 0.2s;
    text-decoration: none;
  }
  .lb-btn:hover { background: rgba(255,255,255,0.18); transform: scale(1.1); }
  .lb-btn svg { width: 1.1rem; height: 1.1rem; }

  .lb-img-wrap {
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    min-height: 200px;
    max-height: calc(92vh - 5rem);
    touch-action: none;
  }

  .lb-img {
    max-width: 100%; max-height: calc(92vh - 5rem);
    object-fit: contain; display: block;
    transform-origin: center center;
    transition: none;
    will-change: transform;
    user-select: none;
  }

  .lb-hint {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.68rem; letter-spacing: 0.12em;
    color: rgba(255,255,255,0.28);
    text-align: center; padding: 0.55rem 1rem;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .info-wrap { padding: 1.5rem 1.2rem 1rem; }
    .hero { height: 52vh; }
    .hero-caption { bottom: 2rem; }
    .photo-section { padding: 0 1.2rem 2.5rem; }
    .story-wrap { padding: 0 1.2rem 4rem; }
  }
  @media (max-width: 560px) {
    .hero { height: 46vh; }
    .photo-grid { columns: 2 160px; }
  }
</style>

<script>
  /* ── 入场动画 ─────────────────────────────── */
  function show(sel: string, delay: number) {
    setTimeout(() => document.querySelector(sel)?.classList.add('visible'), delay);
  }
  show('#topnav',  0);
  show('#caption', 180);
  show('#meta',    360);
  show('#photos',  500);
  show('#story',   660);

  /* ── 灯箱 ─────────────────────────────────── */
  const lightbox   = document.getElementById('lightbox')!;
  const lbImg      = document.getElementById('lb-img') as HTMLImageElement;
  const lbDownload = document.getElementById('lb-download') as HTMLAnchorElement;
  const lbClose    = document.getElementById('lb-close')!;
  const lbWrap     = document.getElementById('lb-img-wrap')!;

  let scale = 1;
  let isDragging = false;
  let dragStartX = 0, dragStartY = 0;
  let translateX = 0, translateY = 0;

  function applyTransform() {
    lbImg.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
  }

  function openLightbox(src: string) {
    lbImg.src = src;
    lbDownload.href = src;
    lbDownload.download = src.split('/').pop() ?? 'photo';
    scale = 1; translateX = 0; translateY = 0;
    applyTransform();
    lightbox.setAttribute('aria-hidden', 'false');
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTimeout(() => { lbImg.src = ''; }, 300);
  }

  /* 点击照片 */
  document.querySelectorAll<HTMLElement>('.photo-item').forEach(fig => {
    fig.addEventListener('click', () => {
      const src = fig.dataset.src ?? (fig.querySelector('img') as HTMLImageElement).src;
      openLightbox(src);
    });
  });

  /* 关闭按钮 & 背景点击 */
  lbClose.addEventListener('click', closeLightbox);
  lightbox.querySelector('.lb-backdrop')!.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

  /* 滚轮缩放 */
  lbWrap.addEventListener('wheel', (e: WheelEvent) => {
    e.preventDefault();
    const delta = e.deltaY < 0 ? 0.15 : -0.15;
    scale = Math.min(Math.max(scale + delta, 0.5), 6);
    applyTransform();
  }, { passive: false });

  /* 拖拽移动 */
  lbWrap.addEventListener('mousedown', (e: MouseEvent) => {
    isDragging = true;
    dragStartX = e.clientX - translateX;
    dragStartY = e.clientY - translateY;
    lbWrap.style.cursor = 'grabbing';
  });
  window.addEventListener('mousemove', (e: MouseEvent) => {
    if (!isDragging) return;
    translateX = e.clientX - dragStartX;
    translateY = e.clientY - dragStartY;
    applyTransform();
  });
  window.addEventListener('mouseup', () => {
    isDragging = false;
    lbWrap.style.cursor = '';
  });

  /* 双击重置缩放 */
  lbWrap.addEventListener('dblclick', () => {
    scale = 1; translateX = 0; translateY = 0;
    applyTransform();
  });
</script>
