---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="快门瞬息 | 照片墙">
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;700&display=swap" />

  <!-- 动态渐变背景 -->
  <div class="page-bg" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
  </div>

  <!-- 右上角导航按钮组 -->
  <nav class="top-nav layer-item" id="topnav">
    <a href="/" class="nav-link">主页</a>
    <a href="/gallery" class="nav-link">照片墙</a>
  </nav>

  <!-- 主内容区 -->
  <div class="page-content">

    <header class="page-header">
      <h1 class="page-title layer-item" id="title">📷 快门瞬息</h1>
      <p class="page-sub layer-item" id="sub">定格每一个值得留存的瞬间</p>
    </header>

    <!--
      =====================================================================
      图片展示区域 - 瀑布流 CSS Columns 布局
      =====================================================================

      添加图片方式：
        在 .photo-grid 内部（"在此处添加图片"注释后）插入：

        <figure class="photo-item">
          <img src="/images/photos/your-photo.jpg" alt="照片描述" loading="lazy" />
          <figcaption>可选文字说明</figcaption>
        </figure>

      图片建议放置路径：public/images/photos/
      推荐格式：webp / jpg（文件更小，加载更快）

      布局说明：
        - columns: 3 280px → 最小列宽 280px，最多铺 3 列，自动响应
        - break-inside: avoid → 防止单张图片被列边界截断
        - loading="lazy" → 浏览器原生懒加载，提升性能
      =====================================================================
    -->
    <section class="photo-grid layer-item" id="grid">

      <!-- 暂无图片时的占位提示，添加图片后可删除此 div -->
      <div class="empty-state">
        <span class="empty-icon">🌫️</span>
        <p>照片整理中，敬请期待…</p>
      </div>

      <!-- 在此处添加 <figure class="photo-item"> 图片条目 -->

    </section>

  </div>
</Layout>

<style>
  :root {
    --c1: #31572c;
    --c2: #4f772d;
    --c3: #90a955;
    --c4: #ecf39e;
    --bg-dark: #0d1a09;
  }

  .page-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: var(--bg-dark);
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
  }

  .orb-1 {
    width: 60vw; height: 60vw;
    background: radial-gradient(circle, var(--c2) 0%, var(--c1) 60%, transparent 100%);
    top: -15%; right: -10%;
    opacity: 0.5;
    animation: float1 14s ease-in-out infinite;
  }

  .orb-2 {
    width: 45vw; height: 45vw;
    background: radial-gradient(circle, var(--c1) 0%, transparent 100%);
    bottom: -10%; left: -8%;
    opacity: 0.45;
    animation: float2 18s ease-in-out infinite;
  }

  @keyframes float1 {
    0%,100% { transform: translate(0,0) scale(1); }
    50%     { transform: translate(-3vw, 5vh) scale(1.07); }
  }
  @keyframes float2 {
    0%,100% { transform: translate(0,0) scale(1); }
    50%     { transform: translate(5vw, -5vh) scale(1.1); }
  }

  /* 分层渐显 */
  .layer-item {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity  0.5s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .layer-item.visible {
    opacity: 1;
    transform: none;
  }

  .top-nav {
    position: fixed;
    top: 1.4rem;
    right: 1.6rem;
    z-index: 100;
    display: flex;
    gap: 0.6rem;
  }

  .nav-link {
    padding: 0.45rem 1.1rem;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.75);
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 100px;
    text-decoration: none;
    transition: color 0.3s ease, background 0.3s ease;
  }

  .nav-link:hover {
    color: #fff;
    background: rgba(255,255,255,0.14);
  }

  .page-content {
    min-height: 100svh;
    padding: 0 2rem 4rem;
    color: #fff;
  }

  .page-header {
    padding-top: 16vh;
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #fff;
    text-shadow: 0 0 80px rgba(79, 119, 45, 0.5);
  }

  .page-sub {
    margin-top: 0.7rem;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: rgba(236, 243, 158, 0.6);
  }

  /*
    ===== 瀑布流图片网格 =====
    columns: 最小列宽 280px，自动计算列数（最多约 3-4 列）
    column-gap: 列间距
  */
  .photo-grid {
    columns: 3 280px;
    column-gap: 1.2rem;
  }

  /*
    每张照片的容器
    break-inside: avoid → 防止图片被列边界截断
  */
  .photo-item {
    break-inside: avoid;
    margin-bottom: 1.2rem;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    transition:
      transform  0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.35s ease;
  }

  .photo-item:hover {
    transform: translateY(-5px) scale(1.01);
    box-shadow: 0 16px 40px rgba(79, 119, 45, 0.38);
  }

  /* 图片自适应宽度，保持原始比例 */
  .photo-item img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* 可选图片说明文字 */
  .photo-item figcaption {
    padding: 0.6rem 0.9rem 0.75rem;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: rgba(236, 243, 158, 0.55);
  }

  /* 暂无内容时的占位提示 */
  .empty-state {
    column-span: all;
    text-align: center;
    padding: 4rem 2rem;
    color: rgba(255,255,255,0.3);
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
  }

  .empty-icon {
    display: block;
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  @media (max-width: 560px) {
    .photo-grid  { columns: 2 160px; }
    .page-header { padding-top: 12vh; }
  }
</style>

<script>
  /* 分层渐显：页面加载后立即按层级依次触发 */
  function show(selector: string, delay: number) {
    setTimeout(() => {
      document.querySelector(selector)?.classList.add('visible');
    }, delay);
  }

  show('#topnav', 0);
  show('#title',  40);
  show('#sub',    80);
  show('#grid',   130);
</script>
