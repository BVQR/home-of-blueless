---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

/* ── introduce.md 解析器 ───────────────────────────────────────────── */
interface IntroData {
  info: Record<string, string>;
  tagline: string;
}

function parseIntroduce(raw: string): IntroData {
  const [infoSec = '', , tagSec = ''] = raw.split(/\n---\n/);
  const info: Record<string, string> = {};
  for (const line of infoSec.split('\n')) {
    const m = line.match(/^-\s*([^:\n]+):\s*(.+)$/);
    if (m) info[m[1].trim().toLowerCase()] = m[2].trim();
  }
  const tagline = tagSec.trim().replace(/^\*+|\*+$/g, '').trim();
  return { info, tagline };
}

function fmtTitle(slug: string): string {
  return slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

/* ── 自动发现相册 ──────────────────────────────────────────────────── */
const photosBase = path.join(process.cwd(), 'public', 'images', 'photos');
const IMG = /\.(jpe?g|png|webp|gif|avif)$/i;

const albums = fs.existsSync(photosBase)
  ? fs.readdirSync(photosBase)
      .filter(n => fs.statSync(path.join(photosBase, n)).isDirectory())
      .map(slug => {
        const dir    = path.join(photosBase, slug);
        const mdPath = path.join(dir, 'introduce.md');
        const raw    = fs.existsSync(mdPath) ? fs.readFileSync(mdPath, 'utf-8') : '';
        const { info, tagline } = parseIntroduce(raw);
        const imgs   = fs.readdirSync(dir).filter(f => IMG.test(f)).sort();
        return {
          slug,
          title:   fmtTitle(slug),
          info,
          tagline,
          cover:   imgs[0] ? `/images/photos/${slug}/${imgs[0]}` : null,
          count:   imgs.length,
        };
      })
  : [];
---

<Layout title="快门瞬息 | 照片墙">
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&family=Playfair+Display:ital@0;1&display=swap" />

  <div class="page-bg" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
  </div>

  <nav class="top-nav layer-item" id="topnav">
    <a href="/" class="nav-link">主页</a>
    <a href="/gallery" class="nav-link">照片墙</a>
  </nav>

  <div class="page-content">
    <header class="page-header">
      <h1 class="page-title layer-item" id="title">📷 快门瞬息</h1>
      <p class="page-sub layer-item" id="sub">定格每一个值得留存的瞬间</p>
    </header>

    <section class="album-grid layer-item" id="grid">
      {albums.length === 0
        ? (
          <div class="empty-state">
            <span class="empty-icon">🌫️</span>
            <p>相册整理中，敬请期待…</p>
          </div>
        )
        : albums.map(album => (
          <a href={`/gallery/photos/${album.slug}`} class="album-card">
            <div class="album-cover">
              {album.cover
                ? <img src={album.cover} alt={album.title} loading="lazy" />
                : <div class="album-cover-ph">📷</div>
              }
              <div class="album-overlay">
                <span class="album-count">{album.count} 张</span>
                <div class="album-overlay-bottom">
                  {album.info.date    && <span class="album-date">{album.info.date}</span>}
                  {album.info.address && <span class="album-addr">📍 {album.info.address}</span>}
                </div>
              </div>
            </div>
            <div class="album-foot">
              <h2 class="album-title">{album.title}</h2>
              {album.tagline && <p class="album-tagline">{album.tagline}</p>}
            </div>
          </a>
        ))
      }
    </section>
  </div>
</Layout>

<style>
  :root {
    --c1: #31572c;
    --c2: #4f772d;
    --c3: #90a955;
    --c4: #ecf39e;
    --bg-dark: #0d1a09;
  }

  .page-bg {
    position: fixed; inset: 0; z-index: -1;
    background: var(--bg-dark); overflow: hidden;
  }

  .orb { position: absolute; border-radius: 50%; filter: blur(90px); }

  .orb-1 {
    width: 60vw; height: 60vw;
    background: radial-gradient(circle, var(--c2) 0%, var(--c1) 60%, transparent 100%);
    top: -15%; right: -10%; opacity: 0.5;
    animation: float1 14s ease-in-out infinite;
  }
  .orb-2 {
    width: 45vw; height: 45vw;
    background: radial-gradient(circle, var(--c1) 0%, transparent 100%);
    bottom: -10%; left: -8%; opacity: 0.45;
    animation: float2 18s ease-in-out infinite;
  }

  @keyframes float1 {
    0%,100% { transform: translate(0,0) scale(1); }
    50%     { transform: translate(-3vw, 5vh) scale(1.07); }
  }
  @keyframes float2 {
    0%,100% { transform: translate(0,0) scale(1); }
    50%     { transform: translate(5vw, -5vh) scale(1.1); }
  }

  .layer-item {
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.55s cubic-bezier(0.16,1,0.3,1),
                transform 0.55s cubic-bezier(0.16,1,0.3,1);
  }
  .layer-item.visible { opacity: 1; transform: none; }

  .top-nav {
    position: fixed; top: 1.4rem; right: 1.6rem;
    z-index: 100; display: flex; gap: 0.6rem;
  }
  .nav-link {
    padding: 0.45rem 1.1rem;
    font-size: 0.82rem; font-weight: 600; letter-spacing: 0.1em;
    color: rgba(255,255,255,0.75);
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 100px; text-decoration: none;
    transition: color 0.3s, background 0.3s;
    font-family: 'Noto Sans SC', sans-serif;
  }
  .nav-link:hover { color: #fff; background: rgba(255,255,255,0.14); }

  .page-content {
    min-height: 100svh;
    padding: 0 2.5rem 6rem;
    color: #fff;
    max-width: 1400px;
    margin: 0 auto;
  }
  .page-header { padding-top: 16vh; margin-bottom: 3rem; }

  .page-title {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 700; letter-spacing: 0.04em; color: #fff;
    text-shadow: 0 0 80px rgba(79,119,45,0.5);
  }
  .page-sub {
    margin-top: 0.7rem;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.9rem; font-weight: 400; letter-spacing: 0.1em;
    color: rgba(236,243,158,0.6);
  }

  /* ── 相册网格 ─────────────────────────────── */
  .album-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .album-card {
    display: block; text-decoration: none; color: inherit;
    border-radius: 16px; overflow: hidden;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.4s;
    cursor: pointer;
  }
  .album-card:hover {
    transform: translateY(-10px) scale(1.015);
    box-shadow: 0 28px 70px rgba(79,119,45,0.45);
  }

  .album-cover {
    position: relative; aspect-ratio: 4/3;
    overflow: hidden; background: rgba(0,0,0,0.3);
  }
  .album-cover img {
    width: 100%; height: 100%; display: block;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  .album-card:hover .album-cover img { transform: scale(1.07); }

  .album-cover-ph {
    display: flex; align-items: center; justify-content: center;
    width: 100%; height: 100%; font-size: 3rem; opacity: 0.25;
  }

  .album-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      160deg,
      transparent 0%,
      rgba(0,0,0,0.08) 50%,
      rgba(0,0,0,0.7) 100%
    );
    display: flex; flex-direction: column;
    justify-content: space-between; padding: 1rem 1.2rem;
  }

  .album-count {
    align-self: flex-end;
    background: rgba(0,0,0,0.4); backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: rgba(255,255,255,0.85); padding: 0.22rem 0.65rem;
    border-radius: 100px; font-size: 0.72rem; letter-spacing: 0.08em;
    border: 1px solid rgba(255,255,255,0.15);
    font-family: 'Noto Sans SC', sans-serif;
  }

  .album-overlay-bottom { display: flex; flex-direction: column; gap: 0.15rem; }

  .album-date, .album-addr {
    font-size: 0.76rem; color: rgba(255,255,255,0.82);
    letter-spacing: 0.05em; text-shadow: 0 1px 4px rgba(0,0,0,0.6);
    font-family: 'Noto Sans SC', sans-serif;
  }

  .album-foot { padding: 1rem 1.2rem 1.35rem; }

  .album-title {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 1.1rem; font-weight: 600; letter-spacing: 0.04em;
    color: #fff; margin-bottom: 0.35rem;
  }
  .album-tagline {
    font-family: 'Playfair Display', serif;
    font-style: italic; font-size: 0.8rem;
    color: rgba(236,243,158,0.55); letter-spacing: 0.04em; line-height: 1.5;
  }

  .empty-state {
    grid-column: 1 / -1; text-align: center; padding: 5rem 2rem;
    color: rgba(255,255,255,0.3);
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.9rem; letter-spacing: 0.1em;
  }
  .empty-icon { display: block; font-size: 3rem; margin-bottom: 1rem; opacity: 0.5; }

  @media (max-width: 768px) {
    .album-grid { grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); }
  }
  @media (max-width: 560px) {
    .page-content { padding: 0 1.2rem 4rem; }
    .page-header  { padding-top: 12vh; }
    .album-grid   { grid-template-columns: 1fr; gap: 1.2rem; }
  }
</style>

<script>
  function show(sel: string, delay: number) {
    setTimeout(() => document.querySelector(sel)?.classList.add('visible'), delay);
  }
  show('#topnav', 0);
  show('#title',  40);
  show('#sub',    80);
  show('#grid',   130);
</script>
