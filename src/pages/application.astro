---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blueless的实践基地 | BL Blog">
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;700;900&display=swap" />

  <!-- 动态渐变背景 -->
  <div class="page-bg" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <!-- 右上角主页按钮 -->
  <a href="/" class="home-btn layer-item" id="home">主页</a>

  <!-- 主内容区 -->
  <div class="page-content">

    <!-- 标题区域：右对齐 -->
    <section class="slogan-section">
      <div class="slogan-container">
        <h1 class="slogan-1 layer-item" id="s1">Blueless的实践基地</h1>
        <p class="subtitle layer-item" id="subtitle">——尚未动工的地基</p>
      </div>
    </section>

  </div>
</Layout>

<style>
  :root {
    --c1: #f72585;
    --c2: #7209b7;
    --c3: #3a0ca3;
    --c4: #4361ee;
    --c5: #4cc9f0;
    --bg-dark: #07020f;
  }

  .page-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: var(--bg-dark);
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
  }

  .orb-1 {
    width: 60vw; height: 60vw;
    background: radial-gradient(circle, var(--c1) 0%, var(--c2) 55%, transparent 100%);
    top: -20%; right: -15%;
    opacity: 0.5;
    animation: float1 14s ease-in-out infinite;
  }

  .orb-2 {
    width: 55vw; height: 55vw;
    background: radial-gradient(circle, var(--c3) 0%, var(--c4) 60%, transparent 100%);
    bottom: -15%; left: -10%;
    opacity: 0.55;
    animation: float2 18s ease-in-out infinite;
  }

  .orb-3 {
    width: 28vw; height: 28vw;
    background: radial-gradient(circle, var(--c5), var(--c4), transparent);
    top: 42%; left: 38%;
    opacity: 0.2;
    animation: float3 11s ease-in-out infinite;
  }

  @keyframes float1 {
    0%,100% { transform: translate(0,0) scale(1); }
    33%     { transform: translate(-4vw, 6vh) scale(1.08); }
    66%     { transform: translate(3vw, -4vh) scale(0.94); }
  }
  @keyframes float2 {
    0%,100% { transform: translate(0,0) scale(1); }
    50%     { transform: translate(6vw, -6vh) scale(1.12); }
  }
  @keyframes float3 {
    0%,100% { transform: translate(0,0); opacity: .2; }
    50%     { transform: translate(-3vw, 4vh); opacity: .32; }
  }

  /* 分层渐显 */
  .layer-item {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity  0.55s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .layer-item.visible {
    opacity: 1;
    transform: none;
  }

  .home-btn {
    position: fixed;
    top: 1.4rem;
    right: 1.6rem;
    z-index: 100;
    padding: 0.45rem 1.2rem;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.75);
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 100px;
    text-decoration: none;
    transition: color 0.3s ease, background 0.3s ease;
  }

  .home-btn:hover {
    color: #fff;
    background: rgba(255,255,255,0.14);
  }

  .page-content {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 0 1.5rem 4rem;
    color: #fff;
  }

  /* 标题区域：左对齐 */
  .slogan-section {
    flex: 1;
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 960px;
    padding-top: 14vh;
    padding-bottom: 4vh;
    justify-content: flex-start;
  }

  .slogan-container {
    text-align: left;
  }

  .slogan-1 {
    font-family: 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    font-size: clamp(2rem, 6.5vw, 5rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: 0.02em;
    color: #fff;
    text-shadow: 0 0 100px rgba(247, 37, 133, 0.4);
  }

  .subtitle {
    margin-top: 1.2rem;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: rgba(76, 201, 240, 0.65);
  }

  @media (max-width: 560px) {
    .slogan-1 { font-size: clamp(1.8rem, 6vw, 5rem); }
  }
</style>

<script>
  /* 分层渐显：页面加载后立即按层级依次触发，delay 控制在 150ms 以内 */
  function show(selector: string, delay: number) {
    setTimeout(() => {
      document.querySelector(selector)?.classList.add('visible');
    }, delay);
  }

  show('#home',     0);
  show('#s1',       40);
  show('#subtitle', 90);
</script>
